generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserStatus {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(50) // ACTIVE, SUSPENDED, BANNED, dll
  name        String?  @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now())

  users     User[]
  histories UserStatusHistory[]
}

model Role {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(100)
  name        String?  @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now())

  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique @db.VarChar(255)
  name     String? @db.VarChar(255)
  avatar   String? @db.VarChar(255)
  password String  @db.VarChar(255)

  status   UserStatus @relation(fields: [statusId], references: [id])
  statusId Int

  // Increment this when user's roles/permissions change to invalidate existing access tokens
  tokenVersion Int @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  roles           UserRole[]
  tokens          RefreshToken[]
  statusHistories UserStatusHistory[]
}

model UserRole {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId Int

  assignedAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model RefreshToken {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  tokenHash           String    @db.VarChar(255)
  replacedByTokenHash String?   @db.VarChar(255)
  expiresAt           DateTime
  revokedAt           DateTime?
  createdAt           DateTime  @default(now())

  @@index([userId])
}

model UserStatusHistory {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  status   UserStatus @relation(fields: [statusId], references: [id])
  statusId Int

  startAt   DateTime  @default(now())
  endAt     DateTime? // null = permanen
  reason    String?   @db.Text
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([statusId])
}

model Test {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now())
}

// Permission models for RBAC
model PermissionGroup {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(150)
  name        String?  @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now())

  permissions Permission[]
}

model Permission {
  id          Int              @id @default(autoincrement())
  key         String           @unique @db.VarChar(150) // e.g. users.create, users.view
  name        String?          @db.VarChar(255)
  description String?          @db.Text
  group       PermissionGroup? @relation(fields: [groupId], references: [id])
  groupId     Int?
  createdAt   DateTime         @default(now())

  categories Category[]

  rolePermissions RolePermission[]
}

model RolePermission {
  id Int @id @default(autoincrement())

  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId Int

  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId Int

  assignedAt DateTime @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model HeroSection {
  id          Int      @id @default(autoincrement())
  source      String   @db.Text // URL video atau gambar
  title       String   @db.VarChar(500)
  description String   @db.Text
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PageHero {
  id       Int     @id @default(autoincrement())
  pageSlug String  @unique @db.VarChar(100)
  imageUrl String? @db.VarChar(500)
  title    String? @db.VarChar(500)
  subtitle String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageSlug])
}

model CollaborationContent {
  id              Int      @id @default(autoincrement())
  pageKey         String   @unique @db.VarChar(100)
  googleFormUrl   String   @db.Text
  whatsappNumber  String   @db.VarChar(30)
  whatsappMessage String   @db.Text
  heroSubHeadline String?  @db.Text
  heroNotes       String?  @db.Text
  whyBenefits     Json?    @db.JsonB
  schemes         Json?    @db.JsonB
  flowSteps       Json?    @db.JsonB
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WebsiteInfo {
  id              Int      @id @default(autoincrement())
  pageKey         String   @unique @default("default") @db.VarChar(50)
  judul           String?  @db.VarChar(255)
  deskripsi       String?
  deskripsiFooter String?
  logoWebsite     String?
  faviconWebsite  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([pageKey])
}

model ContactSection {
  id               Int      @id @default(autoincrement())
  mapsEmbedUrl     String?  @db.Text
  locationTitle    String?  @db.VarChar(255)
  locationAddress  String?  @db.Text
  operationalHours String?  @db.Text
  whatsappNumber   String?  @db.VarChar(255)
  instagramUrl     String?  @db.VarChar(500)
  twitterUrl       String?  @db.VarChar(500)
  facebookUrl      String?  @db.VarChar(500)
  youtubeUrl       String?  @db.VarChar(500)
  tiktokUrl        String?  @db.VarChar(500)
  email            String?  @db.VarChar(255)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive])
}

// ====================================
// NAVIGASI & KATEGORI
// ====================================

model Category {
  id          Int     @id @default(autoincrement())
  title       String  @db.VarChar(255)
  slug        String  @unique @db.VarChar(255)
  description String? @db.Text
  order       Int     @default(0)
  isActive    Boolean @default(true)

  // Optional: Permission gating untuk visibility kategori
  requiredPermissionId Int?
  requiredPermission   Permission? @relation(fields: [requiredPermissionId], references: [id])

  items CategoryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([order])
}

model CategoryItem {
  id Int @id @default(autoincrement())

  // Relasi ke category parent
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId Int

  // Self-referential untuk hirarki multi-level
  parent   CategoryItem?  @relation("CatChildren", fields: [parentId], references: [id], onDelete: Cascade)
  parentId Int?
  children CategoryItem[] @relation("CatChildren")

  title String  @db.VarChar(255)
  slug  String? @db.VarChar(255)
  url   String? @db.VarChar(500)

  // Order untuk sorting
  order Int @default(0)

  // Metadata flexible (JSON)
  meta Json? @db.JsonB

  isActive      Boolean @default(true)
  isIndependent Boolean @default(false)

  eventCategories    EventCategory[]
  platformCategories PlatformCategory[]
  eventOrganizers    EventOrganizer[]
  platformContents   PlatformContent[]
  programCategories  ProgramCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles          ArticleCategory[]
  programOrganizers ProgramOrganizer[]

  @@index([categoryId])
  @@index([parentId])
  @@index([order])
}

// ====================================
// TEAM
// ====================================

model TeamCategory {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  slug        String  @db.VarChar(255)
  description String? @db.Text
  order       Int     @default(0)
  isActive    Boolean @default(true)

  members TeamMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, name])
  @@index([slug])
  @@index([order])
}

model TeamMember {
  id Int @id @default(autoincrement())

  category   TeamCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId Int

  name      String  @db.VarChar(255)
  slug      String  @db.VarChar(255)
  role      String  @db.VarChar(255)
  imageUrl  String? @db.VarChar(500)
  email     String? @db.VarChar(255)
  instagram String? @db.VarChar(255)
  order     Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, name])
  @@index([categoryId])
  @@index([order])
}

// ====================================
// PLATFORM
// ====================================

model Platform {
  id             Int     @id @default(autoincrement())
  slug           String  @unique @db.VarChar(100)
  name           String  @db.VarChar(255)
  headline       String? @db.VarChar(500)
  subHeadline    String? @db.Text
  instagram      String? @db.VarChar(500)
  youtube        String? @db.VarChar(500)
  youtubeProfile String? @db.VarChar(500)
  mainImageUrl   String? @db.VarChar(500)
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images     PlatformImage[]
  categories PlatformCategory[]
  contents   PlatformContent[]

  @@index([slug])
}

model HomepagePlatformCard {
  id       Int     @id @default(autoincrement())
  title    String  @db.VarChar(255)
  imageUrl String? @db.VarChar(500)
  linkUrl  String? @db.VarChar(500)
  slotType String  @default("tall") @db.VarChar(20)
  order    Int     @default(0)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([isActive])
}

model PlatformCategory {
  id         Int      @id @default(autoincrement())
  platform   Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  platformId Int

  // Sumber title, slug, url diambil dari CategoryItem (nav tree)
  categoryItem   CategoryItem @relation(fields: [categoryItemId], references: [id], onDelete: Cascade)
  categoryItemId Int

  // Metadata visual khusus halaman platform
  layout      String  @default("grid") @db.VarChar(50) // 'grid' | 'carousel'
  description String? @db.Text
  filters     Json?   @db.JsonB // string[] untuk filter grid
  order       Int     @default(0)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([platformId, categoryItemId])
  @@index([platformId])
  @@index([categoryItemId])
  @@index([order])
}

model PlatformImage {
  id         Int      @id @default(autoincrement())
  platform   Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  platformId Int

  key      String  @db.VarChar(100)
  type     String  @db.VarChar(50)
  label    String  @db.VarChar(255)
  title    String? @db.VarChar(500)
  subtitle String? @db.Text
  imageUrl String? @db.VarChar(500)
  order    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([platformId, key])
  @@index([platformId])
  @@index([type])
}

model PlatformContent {
  id Int @id @default(autoincrement())

  platform   Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  platformId Int

  // Kategori konten — mengacu ke CategoryItem (sub-nav platform)
  categoryItem   CategoryItem? @relation(fields: [categoryItemId], references: [id], onDelete: SetNull)
  categoryItemId Int?

  title           String   @db.VarChar(500)
  url             String?  @db.VarChar(500)
  instagram       String?  @db.VarChar(500)
  youtube         String?  @db.VarChar(500)
  prevdescription String?  @db.Text
  description     String?  @db.Text
  host            String?  @db.VarChar(255)
  guests          String[] // array tamu, disimpan as text[]
  year            Int?
  meta            Json? // flexible metadata (JSON)
  tags            String[] // array tag bebas, disimpan as text[]
  order           Int      @default(0)
  views           Int      @default(0)
  isActive        Boolean  @default(true)

  images PlatformContentImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([platformId])
  @@index([categoryItemId])
  @@index([order])
  @@index([isActive])
}

model PlatformContentImage {
  id Int @id @default(autoincrement())

  content   PlatformContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  contentId Int

  imageUrl String? @db.VarChar(500)
  type     String  @default("thumbnail") @db.VarChar(50) // thumbnail | gallery | cover
  alt      String? @db.VarChar(255)
  order    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contentId])
  @@index([type])
}

model TentangVisiMisi {
  id       Int    @id @default(autoincrement())
  pageSlug String @unique @default("tentang") @db.VarChar(100)

  description String @db.Text
  visi        String @db.Text
  misi        String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageSlug])
}

model TentangSejarahItem {
  id Int @id @default(autoincrement())

  title    String  @db.VarChar(255)
  imageUrl String? @db.VarChar(500)
  order    Int     @default(0)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([isActive])
}

model TentangPanduanVisual {
  id Int @id @default(autoincrement())

  title    String  @db.VarChar(255)
  link     String? @db.VarChar(500)
  order    Int     @default(0)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([isActive])
}

// ====================================
// EVENT
// ====================================

model Event {
  id Int @id @default(autoincrement())

  // BASIC INFO
  title       String  @db.VarChar(255)
  slug        String  @unique @db.VarChar(255)
  description String? @db.Text
  poster      String? @db.VarChar(500)

  // RELASI (MANY TO MANY)
  organizers      EventOrganizer[]
  eventCategories EventCategory[]
  tags            EventTag[]

  // WAKTU
  startAt        DateTime
  endAt          DateTime?
  isFlexibleTime Boolean   @default(false)

  // LOKASI
  location     String? @db.VarChar(255)
  mapsEmbedSrc String? @db.Text

  // LINK
  registerLink      String? @db.VarChar(500)
  driveLink         String? @db.VarChar(500)
  youtubeLink       String? @db.VarChar(500)
  instagramLink     String? @db.VarChar(500)
  drivebukuLink     String? @db.VarChar(500)
  instagramLiveLink String? @db.VarChar(500)
  tiktokLiveLink    String? @db.VarChar(500)
  youtubeLiveLink   String? @db.VarChar(500)

  // PUBLISH
  isPublished Boolean @default(false)

  views Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startAt])
  @@index([endAt])
  @@index([isPublished])
}

model EventCategory {
  eventId        Int
  categoryItemId Int

  // RELASI
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  categoryItem CategoryItem @relation(fields: [categoryItemId], references: [id], onDelete: Cascade)

  // OPTIONAL META (future-proof)
  isPrimary Boolean @default(false)
  order     Int     @default(0)

  @@id([eventId, categoryItemId])
  @@index([eventId])
  @@index([categoryItemId])
}

model EventOrganizer {
  eventId        Int
  categoryItemId Int

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  categoryItem CategoryItem @relation(fields: [categoryItemId], references: [id], onDelete: Cascade)

  @@id([eventId, categoryItemId])
  @@index([eventId])
  @@index([categoryItemId])
}

model EventTag {
  eventId Int
  tagId   Int

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([eventId, tagId])
  @@index([tagId])
  @@index([eventId])
}

// ====================================
// ARTICLES / BLOG / NEWS SYSTEM
// ====================================

model Article {
  id Int @id @default(autoincrement())

  title String @db.VarChar(255)
  slug  String @unique @db.VarChar(255)

  content       String  @db.Text
  excerpt       String? @db.Text
  featuredImage String? @db.VarChar(500)

  // ================= FEATURED IMAGE SOURCE =================
  featuredImageSource String? @db.VarChar(255)

  // ================= REFERENCES =================
  references Json? @db.JsonB

  // ================= AUTHOR (MANUAL) =================
  authorName String  @db.VarChar(255)
  editorName String? @db.VarChar(255)

  // ================= RELATIONS =================

  // Category (pakai tabel Category)
  categories ArticleCategory[]

  // Tags
  tags  ArticleTag[]
  // Media
  media ArticleMedia[]

  // ================= PUBLISHING =================

  status      ArticleStatus @default(DRAFT)
  publishedAt DateTime?

  // ================= SYSTEM =================

  views     Int     @default(0)
  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@index([status, publishedAt])
}

model ArticleCategory {
  articleId  Int
  categoryId Int

  article  Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  category CategoryItem @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([articleId, categoryId])
  @@index([categoryId])
}

model Tag {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(100)
  slug String @unique @db.VarChar(100)

  articles    ArticleTag[]
  events      EventTag[]
  programTags ProgramTag[]
}

model ArticleTag {
  articleId Int
  tagId     Int

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

model ArticleMedia {
  id Int @id @default(autoincrement())

  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId Int

  type  MediaType
  url   String    @db.VarChar(500)
  title String?   @db.VarChar(255)

  order Int @default(0)

  createdAt DateTime @default(now())

  @@index([articleId])
}

enum MediaType {
  YOUTUBE
  GOOGLE_DRIVE
  IMAGE
  FILE
  EMBED
}

// ==========================================
// MODUL PROGRAM & PODCAST
// ==========================================

enum ProgramType {
  UMUM
  HYSTERIA_BERKELANA
}

model Program {
  id          Int         @id @default(autoincrement())
  title       String
  slug        String      @unique
  description String      @db.Text
  poster      String?
  type        ProgramType @default(UMUM)
  isPublished Boolean     @default(false)

  // Jadwal & Tiket
  startAt        DateTime?
  endAt          DateTime?
  isFlexibleTime Boolean   @default(false)
  registerLink   String?

  // Lokasi
  location     String?
  mapsEmbedSrc String? @db.Text

  // Arsip & Link Eksternal
  driveLink     String?
  youtubeLink   String?
  instagramLink String?
  drivebukuLink String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi
  programCategories ProgramCategory[]
  programTags       ProgramTag[]
  programOrganizers ProgramOrganizer[]
}

model Podcast {
  id               Int      @id @default(autoincrement())
  astonLink        String?
  soreDiStonenLink String?
  updatedAt        DateTime @updatedAt
}

// --- TABEL RELASI / JEMBATAN ---

model ProgramCategory {
  id             Int     @id @default(autoincrement())
  programId      Int
  categoryItemId Int
  isPrimary      Boolean @default(false)
  order          Int     @default(0)

  program      Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  categoryItem CategoryItem @relation(fields: [categoryItemId], references: [id], onDelete: Cascade)
}

model ProgramTag {
  id        Int @id @default(autoincrement())
  programId Int
  tagId     Int

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
}

model ProgramOrganizer {
  id             Int @id @default(autoincrement())
  programId      Int
  categoryItemId Int // Mengambil data dari master CategoryItem

  program      Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  categoryItem CategoryItem @relation(fields: [categoryItemId], references: [id], onDelete: Cascade)
}

model PageProgram {
  id       Int    @id @default(autoincrement())
  pageSlug String @unique @default("program") @db.VarChar(100)

  mainHero  Json? @db.JsonB
  covers    Json? @db.JsonB
  slugHeros Json? @db.JsonB

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageSlug])
}

model VisitorStats {
  id            Int      @id @default(autoincrement())
  date          DateTime @unique // Tanggal (start of day)
  articleViews  Int      @default(0)
  eventViews    Int      @default(0)
  platformViews Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}
