# ==========================================
# .env.production — Copy file ini ke VPS dengan nama .env
# JANGAN commit file .env ke repository!
# ==========================================

DATABASE_URL="postgresql://hysteria_user:GANTI_PASSWORD@localhost:5432/hysteria?schema=public"

# Config
NODE_ENV=production
PORT=3000
APP_URL=https://yourdomain.com

# Authentication — Ganti dengan nilai random yang kuat (min 64 karakter)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GANTI_DENGAN_RANDOM_STRING_KUAT_64_KARAKTER
JWT_REFRESH_SECRET=GANTI_DENGAN_RANDOM_STRING_KUAT_BERBEDA_64_KARAKTER

# Admin user (digunakan saat seed pertama kali)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=GANTI_PASSWORD_ADMIN_KUAT
ADMIN_NAME=Super Admin

# ==========================================
# UPLOAD CONFIGURATION
# ==========================================
UPLOAD_STORAGE=local
UPLOAD_LOCAL_PATH=./public/uploads
UPLOAD_PUBLIC_BASE=/uploads
UPLOAD_ALLOWED_TYPES=image/*,video/*
UPLOAD_QUALITY=80
UPLOAD_PRODUCT_DIMENSION=500

# ==========================================
# S3 CONFIGURATION (opsional, untuk production scale)
# ==========================================
# UPLOAD_STORAGE=s3
# S3_BUCKET=nama-bucket
# S3_REGION=ap-southeast-1
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=false
# S3_PUBLIC_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
